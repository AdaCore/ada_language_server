[
   {
      "comment": [
         "Test that toggling semanticDiagnostics correctly clears/restores semantic",
         "diagnostics without touching syntax (parse) diagnostics."
      ]
   },
   {
      "start": {
         "cmd": ["${ALS}"]
      }
   },
   {
      "send": {
         "request": {
            "jsonrpc": "2.0",
            "id": 0,
            "method": "initialize",
            "params": {}
         },
         "wait": []
      }
   },
   {
      "send": {
         "request": {
            "jsonrpc": "2.0",
            "method": "initialized",
            "params": {}
         },
         "wait": []
      }
   },
   {
      "send": {
         "request": {
            "jsonrpc": "2.0",
            "method": "workspace/didChangeConfiguration",
            "params": {
               "settings": {
                  "ada": {
                     "projectFile": "$URI{default.gpr}",
                     "semanticDiagnostics": true
                  }
               }
            }
         },
         "wait": []
      }
   },
   {
      "comment": [
         "Open file with both a semantic error (type mismatch on line 1) and a",
         "syntax error (stray ';' on line 2).  With semanticDiagnostics enabled",
         "we expect both diagnostics to be published."
      ]
   },
   {
      "send": {
         "request": {
            "jsonrpc": "2.0",
            "method": "textDocument/didOpen",
            "params": {
               "textDocument": {
                  "uri": "$URI{src/pkg.ads}",
                  "languageId": "ada",
                  "version": 1,
                  "text": "package Pkg is\n   X : Integer := False;\n;\nend Pkg;\n"
               }
            }
         },
         "wait": [
            {
               "method": "textDocument/publishDiagnostics",
               "params": {
                  "uri": "$URI{src/pkg.ads}",
                  "diagnostics": [
                     {
                        "range": {
                           "start": { "line": 2, "character": 0 },
                           "end": { "line": 2, "character": 1 }
                        },
                        "source": "libadalang",
                        "message": "Skipped token ;"
                     },
                     {
                        "range": {
                           "start": { "line": 1, "character": 18 },
                           "end": { "line": 1, "character": 23 }
                        },
                        "source": "libadalang",
                        "message": "expected Integer, got Boolean"
                     }
                  ]
               }
            }
         ]
      }
   },
   {
      "comment": [
         "Disable semantic diagnostics.",
         "The semantic diagnostic must be cleared and the syntax one must remain."
      ]
   },
   {
      "send": {
         "request": {
            "jsonrpc": "2.0",
            "method": "workspace/didChangeConfiguration",
            "params": {
               "settings": {
                  "ada": {
                     "projectFile": "$URI{default.gpr}",
                     "semanticDiagnostics": false
                  }
               }
            }
         },
         "wait": [
            {
               "method": "textDocument/publishDiagnostics",
               "params": {
                  "uri": "$URI{src/pkg.ads}",
                  "diagnostics": [
                     {
                        "range": {
                           "start": { "line": 2, "character": 0 },
                           "end": { "line": 2, "character": 1 }
                        },
                        "source": "libadalang",
                        "message": "Skipped token ;"
                     }
                  ]
               }
            }
         ]
      }
   },
   {
      "comment": [
         "Re-enable semantic diagnostics.",
         "Both the syntax and semantic diagnostics must be present again."
      ]
   },
   {
      "send": {
         "request": {
            "jsonrpc": "2.0",
            "method": "workspace/didChangeConfiguration",
            "params": {
               "settings": {
                  "ada": {
                     "projectFile": "$URI{default.gpr}",
                     "semanticDiagnostics": true
                  }
               }
            }
         },
         "wait": [
            {
               "method": "textDocument/publishDiagnostics",
               "params": {
                  "uri": "$URI{src/pkg.ads}",
                  "diagnostics": [
                     {
                        "range": {
                           "start": { "line": 2, "character": 0 },
                           "end": { "line": 2, "character": 1 }
                        },
                        "source": "libadalang",
                        "message": "Skipped token ;"
                     },
                     {
                        "range": {
                           "start": { "line": 1, "character": 18 },
                           "end": { "line": 1, "character": 23 }
                        },
                        "source": "libadalang",
                        "message": "expected Integer, got Boolean"
                     }
                  ]
               }
            }
         ]
      }
   },
   {
      "send": {
         "request": {
            "jsonrpc": "2.0",
            "id": "shutdown",
            "method": "shutdown",
            "params": null
         },
         "wait": [{ "id": "shutdown", "result": null }]
      }
   },
   {
      "send": {
         "request": { "jsonrpc": "2.0", "method": "exit" },
         "wait": []
      }
   },
   {
      "stop": {
         "exit_code": 0
      }
   }
]
