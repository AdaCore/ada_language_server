[
   {
      "comment": [
         "Test that Update_Diagnostics correctly evicts a cached diagnostic",
         "when its node is fixed via a ranged didChange."
      ]
   },
   {
      "start": {
         "cmd": ["${ALS}"]
      }
   },
   {
      "send": {
         "request": {
            "jsonrpc": "2.0",
            "id": 0,
            "method": "initialize",
            "params": {}
         },
         "wait": []
      }
   },
   {
      "send": {
         "request": {
            "jsonrpc": "2.0",
            "method": "initialized",
            "params": {}
         },
         "wait": []
      }
   },
   {
      "send": {
         "request": {
            "jsonrpc": "2.0",
            "method": "workspace/didChangeConfiguration",
            "params": {
               "settings": {
                  "ada": {
                     "projectFile": "$URI{default.gpr}",
                     "semanticDiagnostics": true
                  }
               }
            }
         },
         "wait": []
      }
   },
   {
      "comment": "Open file with type mismatch: `X : Integer := False`"
   },
   {
      "send": {
         "request": {
            "jsonrpc": "2.0",
            "method": "textDocument/didOpen",
            "params": {
               "textDocument": {
                  "uri": "$URI{src/pkg.ads}",
                  "languageId": "ada",
                  "version": 1,
                  "text": "package Pkg is\n   X : Integer := False;\nend Pkg;\n"
               }
            }
         },
         "wait": [
            {
               "method": "textDocument/publishDiagnostics",
               "params": {
                  "uri": "$URI{src/pkg.ads}",
                  "diagnostics": [
                     {
                        "range": {
                           "start": { "line": 1, "character": 18 },
                           "end": { "line": 1, "character": 23 }
                        },
                        "source": "libadalang",
                        "message": "expected Integer, got Boolean"
                     }
                  ]
               }
            }
         ]
      }
   },
   {
      "comment": [
         "Ranged change: replace `False` with `0` (chars 18-23 on line 1).",
         "The cached diagnostic must be evicted and the ",
         "re-check must produce no errors, resulting in an empty list."
      ]
   },
   {
      "send": {
         "request": {
            "jsonrpc": "2.0",
            "method": "textDocument/didChange",
            "params": {
               "textDocument": {
                  "uri": "$URI{src/pkg.ads}",
                  "version": 2
               },
               "contentChanges": [
                  {
                     "range": {
                        "start": { "line": 1, "character": 18 },
                        "end": { "line": 1, "character": 23 }
                     },
                     "rangeLength": 5,
                     "text": "0"
                  }
               ]
            }
         },
         "wait": [
            {
               "method": "textDocument/publishDiagnostics",
               "params": {
                  "uri": "$URI{src/pkg.ads}",
                  "diagnostics": []
               }
            }
         ]
      }
   },
   {
      "send": {
         "request": {
            "jsonrpc": "2.0",
            "id": "shutdown",
            "method": "shutdown",
            "params": null
         },
         "wait": [{ "id": "shutdown", "result": null }]
      }
   },
   {
      "send": {
         "request": { "jsonrpc": "2.0", "method": "exit" },
         "wait": []
      }
   },
   {
      "stop": {
         "exit_code": 0
      }
   }
]
